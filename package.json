{
  "name": "eval-quality",
  "version": "0.0.0",
  "description": "Agent evaluation for the reasoning path, not just the output. A provider-agnostic harness that scores an agent's trajectory - tool use, faithfulness, grounding - as evidence, not a benchmark number.",
  "author": "Murat Ozcan",
  "license": "Apache-2.0",
  "private": false,
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "keywords": [
    "eval",
    "evals",
    "evaluation",
    "agent",
    "agent-eval",
    "llm",
    "llm-as-judge",
    "trajectory",
    "reasoning",
    "testing",
    "ai"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "homepage": "https://github.com/muratkeremozcan/eval-quality#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/muratkeremozcan/eval-quality.git"
  },
  "bugs": {
    "url": "https://github.com/muratkeremozcan/eval-quality/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "prepare": "command -v husky >/dev/null 2>&1 && husky || exit 0",
    "build": "tsc -p tsconfig-build.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate": "npm run typecheck && npm run lint && npm run test",
    "prepack": "npm run clean && npm run build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.13",
    "@types/node": "^22.10.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "lint-staged": {
    "*.{ts,js,json}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  }
}
