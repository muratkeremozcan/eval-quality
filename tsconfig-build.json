{
	"extends": "./tsconfig.json",
	"include": ["src"],
	"exclude": ["node_modules", "dist", "tests", "templates"],
	"compilerOptions": {
		"noEmit": false,
		"allowImportingTsExtensions": false,
		"rewriteRelativeImportExtensions": true,
		"declaration": true,
		"declarationDir": "dist",
		"outDir": "dist",
		"rootDir": "src"
	}
}
