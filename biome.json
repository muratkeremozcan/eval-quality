{
	"$schema": "https://biomejs.dev/schemas/2.5.4/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"includes": [
			"**",
			"!**/dist",
			"!package.json",
			"!package-lock.json",
			"!_bmad",
			"!_bmad-output",
			"!.claude",
			"!.agent",
			"!.agents",
			"!docs"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"preset": "recommended",
			"suspicious": {
				"noFocusedTests": "error"
			},
			"style": {
				"useImportType": "error",
				"useExportType": "error"
			}
		}
	},
	"overrides": [
		{
			"includes": ["**/*.d.ts"],
			"linter": {
				"rules": {
					"style": {
						"useExportType": "off",
						"useImportType": "off"
					}
				}
			}
		},
		{
			"includes": ["src/**/*.ts"],
			"linter": {
				"rules": {
					"style": {
						"noNonNullAssertion": "off"
					}
				}
			}
		},
		{
			"includes": ["tests/**/*.ts"],
			"linter": {
				"rules": {
					"suspicious": {
						"noExplicitAny": "off"
					},
					"style": {
						"noNonNullAssertion": "off"
					}
				}
			}
		}
	],
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"semicolons": "asNeeded"
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	}
}
